# Sui
SUI_NETWORK=testnet
SUI_PRIVATE_KEY=

# Odds + AI
ODDS_API_KEY=
# the-odds-api bookmaker region: us | uk | eu | au (default eu)
ODDS_API_REGION=eu
ANTHROPIC_API_KEY=

# Walrus audit trail (HTTP API). Leave publisher unset for stub blobs.
# Public testnet endpoints exist; see https://docs.walrus.site/
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=
WALRUS_EPOCHS=5

# Package IDs (after publish)
IWALLET_PACKAGE_ID=
SPORTSBOOK_PACKAGE_ID=
RESOLVER_CAP_ID=

# Agent identity (after provision)
IIDENTITY_OBJECT_ID=
# Registered identity_hash = Poseidon(w), hex-encoded
IDENTITY_HASH=
# The agent secret witness w, hex-encoded (private; never commit a real value)
AGENT_WITNESS_W=
# Staged-balance bag key
STAGED_BALANCE_KEY=default

# Stake config
STAKE_COIN_TYPE=0x2::sui::SUI

# Circuit artifacts (from upstream `circuits/`). Paths resolved from agent/.
CIRCUIT_WASM=../circuits/iwallet_js/iwallet.wasm
CIRCUIT_ZKEY=../circuits/iwallet_final.zkey
